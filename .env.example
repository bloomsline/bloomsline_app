# Copy to `.env` and fill in. Expo exposes EXPO_PUBLIC_* to the app at build time.

# The Bloomsline backend base URL.
#  - iOS simulator can use http://localhost:3000
#  - Android emulator uses http://10.0.2.2:3000
#  - a real device needs your machine's LAN IP or the deployed URL
EXPO_PUBLIC_API_URL=http://localhost:3000

# Google OAuth client ids (Google Cloud Console). Public identifiers, not secrets.
# The backend must trust the mobile ids via AUTH_GOOGLE_MOBILE_IDS.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# Microsoft (Entra) native app registration. Tenant = a directory GUID/domain
# (PIN it — the backend only trusts a pinned tenant), or 'common'. The backend
# must trust the client id via AUTH_MICROSOFT_MOBILE_IDS.
EXPO_PUBLIC_MICROSOFT_CLIENT_ID=
EXPO_PUBLIC_MICROSOFT_TENANT=

# --- Dev-only preview flags (never set in a production build) ---
# Sign in locally with no backend, to click through the flow.
EXPO_PUBLIC_MOCK_AUTH=
# With MOCK_AUTH: which side to preview — 'practitioner' or 'member' (default).
EXPO_PUBLIC_MOCK_ROLE=
# Preview a signup branch: a = invited (Flow A), b = solo (Flow B); unset = real.
EXPO_PUBLIC_FORCE_FLOW=
